#!/usr/bin/env node
/* eslint-disable */
// Stand-in for the real `openclaw` CLI used in e2e tests. Implements just
// enough of `openclaw gateway --port N` to satisfy our bootstrap state
// machine: bind a TCP listener so isPortListening() returns true, then idle
// until SIGTERM. Real openclaw is what ships to users; this avoids slow
// npm installs and host dependencies in CI.

const net = require('net')

const args = process.argv.slice(2)
if (args[0] !== 'gateway') {
  console.error('[fake-openclaw] only `gateway` is implemented; got', args.join(' '))
  process.exit(2)
}

const portIdx = args.indexOf('--port')
const port = portIdx >= 0 ? Number(args[portIdx + 1]) : 18789
if (!Number.isInteger(port) || port <= 0) {
  console.error('[fake-openclaw] invalid --port', args[portIdx + 1])
  process.exit(2)
}

const server = net.createServer((socket) => {
  // On any incoming bytes, send a minimal HTTP/1.1 response. The desktop
  // bootstrap's two-phase ready check (TCP listening, THEN a real WS
  // upgrade handshake) needs to see "HTTP/1." come back from the gateway
  // before it'll mark ready — without this the fake gateway looks alive
  // (TCP up) but never speaks, so canHandshakeWebSocket() polls forever.
  // Real openclaw responds with HTTP/1.1 101 Switching Protocols (or 401
  // missing-auth) once its WS handler is wired up.
  let responded = false
  socket.on('data', () => {
    if (responded) return
    responded = true
    socket.write('HTTP/1.1 101 Switching Protocols\r\n\r\n')
  })
  socket.on('error', () => {})
})

server.listen(port, '127.0.0.1', () => {
  console.log(`[fake-openclaw] gateway listening on 127.0.0.1:${port}`)
})

const shutdown = () => {
  server.close(() => process.exit(0))
  setTimeout(() => process.exit(0), 1000).unref()
}
process.on('SIGTERM', shutdown)
process.on('SIGINT', shutdown)
